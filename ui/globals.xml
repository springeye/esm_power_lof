<globals>
	<api>
		<!-- Add <enumdefs> here -->
	</api>

	<consts>
		<!-- Add <px>, <int>, <color> etc here -->
	</consts>

	<styles>
		<!-- Add <style> tags here -->
	</styles>

	<subjects>
		<!--风扇转速百分比-->
		<string name="system_name" value="LOF电源系统" help="风扇转速百分比" />
		<!--设备状态:READY,RUN,STOP-->
		<string name="system_state" value="运行中" />
		<!--设备当前功率(纯数字+单位)-->
		<string name="device_current_power" value="605.25W" />
		<!--开机时间(纯时间，前缀图标在 XML 中)-->
		<string name="uptime" value="00:00:00" />
		<!--瓦时(纯数值+单位，前缀图标在 XML 中)-->
		<string name="wh" value="125.67Wh" />
		<!--设备总功率(设计功率)-->
		<string name="device_power" value="750" />
		<!--当前功率和设计功率的百分比-->
		<int name="device_power_percent" value="31" />
		<string name="device_power_percent_txt" value="31%" />
		<!--通道1的电压-->
		<string name="ch1_voltage" value="0.000" />
		<!--通道1的电流-->
		<string name="ch1_current" value="0.000" />
		<!--通道1的功率-->
		<string name="ch1_pwer" value="0.000" />
		<string name="ch2_voltage" value="0.000" />
		<string name="ch2_current" value="0.000" />
		<string name="ch2_pwer" value="0.000" />
		<string name="ch3_voltage" value="0.000" />
		<string name="ch3_current" value="0.000" />
		<string name="ch3_pwer" value="0.000" />
		<!--设备的温度-->
		<string name="device_temp" value="36.0℃" />
		<!--风扇转速百分比-->
		<string name="fan_percent" value="30%" />
		<string name="fan_rpm_txt" value="0 RPM" help="风扇转速" />
	</subjects>

	<images>
		<!-- Add <file> or <data> tags here -->
	</images>

	<fonts>
		<!-- Add <bin> , <tiny_ttf>, <freetype> tags here -->
		<!--
			SC 字体为简体中文优化版本，用于显示中文字形
			所需中文: 系统温度电压电流功率就绪运行停止通道℃
		-->
		<bin
			name="hos_bold_big"
			as_file="false"
			src_path="fonts/HarmonyOS_Sans_SC_Bold.ttf"
			size="44"
			bpp="8"
			range="0x20-0x7F"
			symbols="电源功耗运行面板系统温度电压电流功率就绪运行中停止通道℃：当前占比时间总能效输出风扇转故障"
		/>
		<bin
			name="hos_regular"
			as_file="false"
			src_path="fonts/HarmonyOS_Sans_SC_Regular.ttf"
			size="16"
			bpp="8"
			range="0x20-0x7F"
			symbols="电源功耗运行面板系统温度电压电流功率就绪运行中停止通道℃：当前占比时间总能效输出风扇转故障"
		/>
		<bin
			name="hos_14"
			as_file="false"
			src_path="fonts/HarmonyOS_Sans_SC_Regular.ttf"
			size="12"
			bpp="8"
			range="0x20-0x7F"
			symbols="电源功耗运行面板系统温度电压电流功率就绪运行中停止通道℃：当前占比时间总能效输出风扇转故障"
		/>
		<bin
			name="font_awesome_14"
			as_file="false"
			src_path="fonts/fa-solid-900.ttf"
			size="14"
			bpp="4"
			range="0xF2C9,0xF0E7,0xF863,0xF017,0xF5DC,0xE55B,0xF1E6,0xF011"
		/>
		<!-- 启动画面专用：仅编入 bolt(0xF0E7)，节省字库体积 -->
		<bin
			name="font_awesome_48"
			as_file="false"
			src_path="fonts/fa-solid-900.ttf"
			size="80"
			bpp="4"
			range="0xF0E7"
		/>
	</fonts>
</globals>
