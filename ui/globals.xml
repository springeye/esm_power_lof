	<subjects>
		<!--风扇转速百分比-->
		<string name="system_name" value="LOF电源系统" help="风扇转速百分比" />
		<!--设备状态:READY,RUN,STOP-->
		<string name="system_state" value="运行中" />
		<!--设备当前功率-->
		<string name="device_current_power" value="功率: 605.00w" />
		<!--开机时间-->
		<string name="uptime" value="运行: 00:00:00" />
		<!--瓦时-->
		<string name="wh" value="功耗：125.21Wh" />
