<screen>
	<styles>
		<style name="style_main" bg_color="0x0a0e14" text_color="0xFFFFFF" />
		<style
			name="no_padding"
			pad_all="0"
			pad_row="0"
			pad_column="0"
			margin_all="0"
			border_width="0"
			outline_pad="0"
			radius="0"
		/>
		<style
			name="card"
			bg_color="0x111820"
			bg_opa="255"
			border_width="1"
			border_color="0x1a2533"
			radius="4"
			pad_all="0"
			pad_row="0"
			pad_column="0"
			margin_all="0"
			outline_pad="0"
		/>
	</styles>

	<view
		style_layout="flex"
		flex_flow="column"
		style_bg_color="0x0a0e14"
		style_bg_opa="255"
		style_pad_all="4"
		style_pad_row="3"
		style_pad_column="0"
		height="100%"
		width="100%"
	>
		<style name="style_main" />
		<style name="no_padding" />

		<!-- 1. 顶栏：左=状态 / 中=风扇 / 右=温度 (高 22) 平铺3 label，无嵌套 -->
		<lv_obj
			width="100%"
			height="22"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="space_between"
			style_flex_cross_place="center"
			style_flex_track_place="center"
			style_bg_color="0x111820"
			style_bg_opa="255"
			style_border_width="1"
			style_border_color="0x1a2533"
			style_radius="3"
			style_pad_left="8"
			style_pad_right="8"
			style_pad_top="0"
			style_pad_bottom="0"
			style_pad_column="0"
		>
			<style name="no_padding" />
			<!-- 左：状态图标+文本 -->
			<lv_obj
				width="content"
				height="100%"
				style_layout="flex"
				flex_flow="row"
				style_flex_cross_place="center"
				style_flex_main_place="start"
				style_bg_opa="0"
				style_pad_column="3"
			>
				<style name="no_padding" />
				<lv_label text="&#xf011;" style_text_color="0x00e68a" style_text_font="font_awesome_14" />
				<lv_label bind_text="system_state" style_text_color="0x00e68a" style_text_font="hos_14" />
			</lv_obj>
			<!-- 中：风扇图标+百分比+转速 -->
			<lv_obj
				width="content"
				height="100%"
				style_layout="flex"
				flex_flow="row"
				style_flex_cross_place="center"
				style_flex_main_place="center"
				style_bg_opa="0"
				style_pad_column="3"
			>
				<style name="no_padding" />
				<lv_label text="&#xf863;" style_text_color="0x3d9eff" style_text_font="font_awesome_14" />
				<lv_label bind_text="fan_percent" style_text_color="0x3d9eff" style_text_font="hos_14" />
				<lv_label bind_text="fan_rpm_txt" style_text_color="0x6b7d8e" style_text_font="hos_14" />
			</lv_obj>
			<!-- 右：温度图标+温度 -->
			<lv_obj
				width="content"
				height="100%"
				style_layout="flex"
				flex_flow="row"
				style_flex_cross_place="center"
				style_flex_main_place="end"
				style_bg_opa="0"
				style_pad_column="3"
			>
				<style name="no_padding" />
				<lv_label text="&#xf2c9;" style_text_color="0xff6b35" style_text_font="font_awesome_14" />
				<lv_label bind_text="device_temp" style_text_color="0xff6b35" style_text_font="hos_14" />
			</lv_obj>
		</lv_obj>

		<!-- 2. 大功率显示 (高 52) -->
		<lv_obj
			width="100%"
			height="52"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="center"
			style_flex_cross_place="center"
			style_flex_track_place="center"
			style_bg_opa="0"
			style_pad_column="0"
		>
			<style name="no_padding" />
			<lv_label bind_text="device_current_power" style_text_color="0x00e68a" style_text_font="hos_bold_big" />
		</lv_obj>

		<!-- 3. 进度条行：bolt + 百分比 + bar 同行 (高 14) -->
		<lv_obj
			width="100%"
			height="14"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="center"
			style_flex_cross_place="center"
			style_flex_track_place="center"
			style_bg_opa="0"
			style_pad_left="6"
			style_pad_right="6"
			style_pad_column="5"
		>
			<style name="no_padding" />
			<lv_label text="&#xf0e7;" style_text_color="0xffb020" style_text_font="font_awesome_14" />
			<lv_label bind_text="device_power_percent_txt" style_text_color="0xffb020" style_text_font="hos_14" width="38" />
			<lv_bar
				width="100%"
				style_flex_grow="1"
				height="8"
				bind_value="device_power_percent"
				style_radius="4"
				style_bg_color="0x111820"
				style_bg_opa="255"
				style_border_width="1"
				style_border_color="0x1a2533"
			/>
		</lv_obj>

		<!-- 4. 双宫格：运行时间 + 累计电量 (高 32) -->
		<lv_obj
			width="100%"
			height="32"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="space_between"
			style_flex_cross_place="center"
			style_flex_track_place="center"
			style_bg_opa="0"
			style_pad_column="4"
		>
			<style name="no_padding" />

			<!-- 卡片1：运行时间 -->
			<lv_obj
				width="0%"
				style_flex_grow="1"
				height="100%"
				style_layout="flex"
				flex_flow="row"
				style_flex_main_place="center"
				style_flex_cross_place="center"
				style_flex_track_place="center"
				style_pad_column="6"
				style_pad_left="5"
				style_pad_right="5"
			>
				<style name="card" />
				<lv_label text="&#xf017;" style_text_color="0x6b7d8e" style_text_font="font_awesome_14" />
				<lv_label bind_text="uptime" style_text_color="0xFFFFFF" style_text_font="hos_14" />
			</lv_obj>

			<!-- 卡片2：累计电量 -->
			<lv_obj
				width="0%"
				style_flex_grow="1"
				height="100%"
				style_layout="flex"
				flex_flow="row"
				style_flex_main_place="center"
				style_flex_cross_place="center"
				style_flex_track_place="center"
				style_pad_column="6"
				style_pad_left="5"
				style_pad_right="5"
			>
				<style name="card" />
				<lv_label text="&#xf5dc;" style_text_color="0xb968ff" style_text_font="font_awesome_14" />
				<lv_label bind_text="wh" style_text_color="0xFFFFFF" style_text_font="hos_14" />
			</lv_obj>

		</lv_obj>

		<!-- 5. 三通道分组（flex_grow=1 吃掉剩余高度） -->
		<lv_obj
			width="100%"
			height="0%"
			style_flex_grow="1"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="space_between"
			style_flex_cross_place="center"
			style_flex_track_place="center"
			style_bg_opa="0"
			style_pad_column="4"
		>
			<style name="no_padding" />

			<!-- CH1 -->
			<lv_obj
				width="0%"
				style_flex_grow="1"
				height="100%"
				style_layout="flex"
				flex_flow="column"
			>
				<style name="card" />
				<lv_obj
					width="100%"
					height="18"
					style_layout="flex"
					flex_flow="row"
					style_flex_main_place="center"
					style_flex_cross_place="center"
					style_flex_track_place="center"
					style_bg_opa="0"
					style_border_width="2"
					style_border_color="0x00e68a"
					style_border_side="bottom"
				>
					<style name="no_padding" />
					<lv_label text="CH1" style_text_color="0x00e68a" style_text_font="hos_14" />
				</lv_obj>
				<lv_obj
					width="100%"
					height="0%"
					style_flex_grow="1"
					style_layout="flex"
					flex_flow="column"
					style_flex_main_place="space_evenly"
					style_flex_cross_place="center"
					style_flex_track_place="center"
					style_bg_opa="0"
					style_pad_top="2"
					style_pad_bottom="2"
				>
					<style name="no_padding" />
					<lv_label bind_text="ch1_voltage" style_text_color="0xFFFFFF" style_text_font="hos_14" />
					<lv_label bind_text="ch1_current" style_text_color="0xFFFFFF" style_text_font="hos_14" />
					<lv_label bind_text="ch1_pwer" style_text_color="0x00e68a" style_text_font="hos_regular" />
				</lv_obj>
			</lv_obj>

			<!-- CH2 -->
			<lv_obj
				width="0%"
				style_flex_grow="1"
				height="100%"
				style_layout="flex"
				flex_flow="column"
			>
				<style name="card" />
				<lv_obj
					width="100%"
					height="18"
					style_layout="flex"
					flex_flow="row"
					style_flex_main_place="center"
					style_flex_cross_place="center"
					style_flex_track_place="center"
					style_bg_opa="0"
					style_border_width="2"
					style_border_color="0xffb020"
					style_border_side="bottom"
				>
					<style name="no_padding" />
					<lv_label text="CH2" style_text_color="0xffb020" style_text_font="hos_14" />
				</lv_obj>
				<lv_obj
					width="100%"
					height="0%"
					style_flex_grow="1"
					style_layout="flex"
					flex_flow="column"
					style_flex_main_place="space_evenly"
					style_flex_cross_place="center"
					style_flex_track_place="center"
					style_bg_opa="0"
					style_pad_top="2"
					style_pad_bottom="2"
				>
					<style name="no_padding" />
					<lv_label bind_text="ch2_voltage" style_text_color="0xFFFFFF" style_text_font="hos_14" />
					<lv_label bind_text="ch2_current" style_text_color="0xFFFFFF" style_text_font="hos_14" />
					<lv_label bind_text="ch2_pwer" style_text_color="0xffb020" style_text_font="hos_regular" />
				</lv_obj>
			</lv_obj>

			<!-- CH3 -->
			<lv_obj
				width="0%"
				style_flex_grow="1"
				height="100%"
				style_layout="flex"
				flex_flow="column"
			>
				<style name="card" />
				<lv_obj
					width="100%"
					height="18"
					style_layout="flex"
					flex_flow="row"
					style_flex_main_place="center"
					style_flex_cross_place="center"
					style_flex_track_place="center"
					style_bg_opa="0"
					style_border_width="2"
					style_border_color="0x3d9eff"
					style_border_side="bottom"
				>
					<style name="no_padding" />
					<lv_label text="CH3" style_text_color="0x3d9eff" style_text_font="hos_14" />
				</lv_obj>
				<lv_obj
					width="100%"
					height="0%"
					style_flex_grow="1"
					style_layout="flex"
					flex_flow="column"
					style_flex_main_place="space_evenly"
					style_flex_cross_place="center"
					style_flex_track_place="center"
					style_bg_opa="0"
					style_pad_top="2"
					style_pad_bottom="2"
				>
					<style name="no_padding" />
					<lv_label bind_text="ch3_voltage" style_text_color="0xFFFFFF" style_text_font="hos_14" />
					<lv_label bind_text="ch3_current" style_text_color="0xFFFFFF" style_text_font="hos_14" />
					<lv_label bind_text="ch3_pwer" style_text_color="0x3d9eff" style_text_font="hos_regular" />
				</lv_obj>
			</lv_obj>
		</lv_obj>
	</view>
</screen>
