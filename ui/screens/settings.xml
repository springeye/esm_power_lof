<screen>
	<styles>
		<style
			name="style_main"
			bg_color="0x0a0e14"
			bg_opa="255"
			text_color="0xFFFFFF"
			pad_all="0"
			border_width="0"
		/>
		<style
			name="style_item"
			bg_color="0x111820"
			border_color="0x1a2533"
			border_width="1"
			radius="3"
			pad_all="4"
		/>
		<style
			name="style_no_pad"
			pad_all="0"
			pad_row="0"
			pad_column="0"
			margin_all="0"
			border_width="0"
			radius="0"
		/>
	</styles>

	<view
		width="100%"
		height="100%"
		style_layout="flex"
		flex_flow="column"
		style_bg_color="0x0a0e14"
		style_bg_opa="255"
		style_pad_all="4"
		style_pad_row="0"
		style_pad_column="0"
	>
		<style name="style_main" />
		<style name="style_no_pad" />

		<!-- 标题栏 -->
		<lv_obj
			width="100%"
			height="22"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="space_between"
			style_flex_cross_place="center"
			style_bg_color="0x111820"
			style_bg_opa="255"
			style_border_width="1"
			style_border_color="0x1a2533"
			style_radius="3"
			style_pad_left="6"
			style_pad_right="6"
			style_pad_top="0"
			style_pad_bottom="0"
		>
			<style name="style_no_pad" />
			<lv_label text="&#xf060;" style_text_font="font_awesome_14" style_text_color="0xFFFFFF" />
			<lv_label text="设置" style_text_font="hos_14" style_text_color="0xFFFFFF" />
			<lv_label text="1/5" style_text_font="hos_14" style_text_color="0xFFFFFF" />
		</lv_obj>

		<!-- 内容区（由 settings_ui.cpp 动态填充） -->
		<lv_obj
			width="100%"
			height="0%"
			style_flex_grow="1"
			style_layout="flex"
			flex_flow="column"
			style_bg_opa="0"
			style_border_width="0"
			style_pad_all="0"
			style_pad_row="4"
			style_pad_column="0"
		>
			<style name="style_no_pad" />
		</lv_obj>

		<!-- 底部提示栏 -->
		<lv_obj
			width="100%"
			height="18"
			style_layout="flex"
			flex_flow="row"
			style_flex_main_place="center"
			style_flex_cross_place="center"
			style_bg_opa="0"
			style_border_width="0"
			style_pad_all="0"
		>
			<style name="style_no_pad" />
			<lv_label text="K1/K3:移动  K2:编辑  长按K2:返回" style_text_font="hos_14" style_text_color="0x6b7d8e" />
		</lv_obj>
	</view>
</screen>
